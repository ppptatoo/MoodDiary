<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="56dp"
    android:layout_height="72dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- 无日记：浅灰圆 -->
    <FrameLayout
        android:id="@+id/fl_empty_day"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_history_date_empty"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_day_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- 有日记：圆角方块 + 表情图标 -->
    <FrameLayout
        android:id="@+id/fl_mood_day"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/ll_mood_icon_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_mood_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_day_on_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- 无图标仅有记录时的小圆点（备用，与图1一致） -->
    <View
        android:id="@+id/view_mood_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_mood_dot"
        android:visibility="gone" />

</FrameLayout>
