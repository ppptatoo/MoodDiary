<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/history_page_bg"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/fl_mood_badge"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_history_date_empty">

                    <ImageView
                        android:id="@+id/iv_detail_mood_icon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:contentDescription="心情图标"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_detail_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:background="@color/divider_color" />

            <FrameLayout
                android:id="@+id/fl_image_container"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_stat_card"
                android:clickable="true"
                android:contentDescription="日记图片区域"
                android:focusable="true"
                android:foregroundGravity="center"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/iv_detail_img"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="日记配图"
                    android:scaleType="centerCrop" />

                <TextView
                    android:id="@+id/tv_change_image_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_detail_chip"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="更换图片"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_add_image_entry"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input_warm"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="添加或替换图片"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_view_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_stat_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tv_detail_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/et_detail_content"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_stat_card"
                android:gravity="top|start"
                android:hint="写下此刻的感受..."
                android:inputType="textMultiLine"
                android:lineSpacingExtra="8dp"
                android:padding="18dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="18sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_edit_mood_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="调整心情"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <GridLayout
                android:id="@+id/grid_edit_moods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="3"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_created_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/card_white"
        android:baselineAligned="false"
        android:elevation="10dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_cancel"
            android:gravity="center"
            android:text="返回"
            android:textColor="@color/text_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/btn_delete_image"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_cancel"
            android:gravity="center"
            android:text="删除图片"
            android:textColor="#C04B4B"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_delete_diary"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_delete"
            android:gravity="center"
            android:text="删除日记"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />    

        <TextView
            android:id="@+id/btn_edit"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_primary_soft"
            android:gravity="center"
            android:text="编辑"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
